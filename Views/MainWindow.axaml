<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SOE_PubEditor.ViewModels"
        xmlns:views="using:SOE_PubEditor.Views"
        xmlns:pub="using:Moffat.EndlessOnline.SDK.Protocol.Pub"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="650"
        x:Class="SOE_PubEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/icon.png"
        Title="Shards of Eternity - Pub File Editor"
        Width="750" Height="650">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Config..." Click="OnConfigClick" InputGesture="Ctrl+,"/>
                <Separator/>
                <MenuItem Header="_Save All" Command="{Binding SaveAllCommand}" InputGesture="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="Export All _GFX to BMP..." Click="OnExportAllGfxClick"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Grid DockPanel.Dock="Bottom" Background="{StaticResource BackgroundMediumBrush}" Height="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="8,0" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="{Binding PubDirectory, StringFormat='Pub: {0}'}" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
            <TextBlock Grid.Column="2" Text="{Binding SaveDirectory, StringFormat='Save: {0}'}" 
                       VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource AccentSuccessBrush}" FontSize="11"
                       IsVisible="{Binding SaveDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            <TextBlock Grid.Column="3" Text="{Binding GfxDirectory, StringFormat='GFX: {0}'}" VerticalAlignment="Center" Margin="8,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
        </Grid>

        <!-- Main Content Tabs -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">
            
            <!-- ═══════════════════════════════════════════ -->
            <!-- Items Tab -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="Items">
                <DockPanel>
                    <!-- Toolbar — Full Width -->
                    <Border DockPanel.Dock="Top" Classes="Toolbar">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding ItemTypeFilters}" SelectedItem="{Binding SelectedItemTypeFilter}" 
                                      Width="110" PlaceholderText="All Types" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="✕" Click="OnClearItemTypeFilter" Padding="4,3" Margin="0,0,8,0"
                                    ToolTip.Tip="Show all types" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Text="{Binding ItemSearchText}" Width="140" Watermark="🔍 Search items..." Margin="0,0,4,0"/>
                            <Panel Grid.Column="3"/>
                            <Button Grid.Column="4" Content="+ Add" Command="{Binding AddItemCommand}" Classes="Primary" Margin="0,0,4,0"
                                    ToolTip.Tip="Add new item"/>
                            <Button Grid.Column="5" Content="Delete" Command="{Binding DeleteItemCommand}" Classes="Danger"
                                    IsEnabled="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                                    ToolTip.Tip="Delete selected item"/>
                        </Grid>
                    </Border>
                    
                    <!-- Content: List + Editor -->
                    <Grid ColumnDefinitions="220,*">
                        <!-- Items List -->
                        <ListBox Grid.Column="0"
                                 ItemsSource="{Binding FilteredItems}" 
                                 SelectedItem="{Binding SelectedItem}"
                                 Margin="6,6,3,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{ReflectionBinding Id, StringFormat='#{0}'}" 
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Width="32"/>
                                        <TextBlock Text="{ReflectionBinding Name}" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <!-- Items Editor Panel -->
                        <Border Grid.Column="1" Classes="EditorPanel" Margin="3,6,6,6">
                            <ScrollViewer>
                                <StackPanel IsVisible="{Binding SelectedItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <!-- Gold Accent Bar -->
                                    <Border Classes="GoldAccent"/>
                                    <TextBlock Text="Item Editor" Classes="PanelTitle"/>
                                    
                                    <!-- GFX Previews -->
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Inventory" FontSize="10" Classes="Label" Margin="0,0,0,3"/>
                                            <Button Click="OnItemPreviewClick" Padding="0" HorizontalAlignment="Left"
                                                    ToolTip.Tip="Click to choose inventory/ground icon">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Export All Graphics..." Click="OnExportItemGraphics"/>
                                                        <MenuItem Header="Import Graphics..." Click="OnImportItemGraphics"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Border Classes="GfxPreview" Height="64" Width="64">
                                                    <Image Source="{Binding ItemPreview}" Stretch="None"/>
                                                </Border>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel IsVisible="{Binding ShowEquipmentPreview}">
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,3">
                                                <TextBlock Text="Equipment" FontSize="10" Classes="Label"/>
                                                <ComboBox SelectedIndex="{Binding SelectedItem.Spec2}" 
                                                          IsVisible="{Binding ShowGenderSelector}"
                                                          FontSize="10" Padding="3,1" MinWidth="60"
                                                          ToolTip.Tip="Gender">
                                                    <ComboBoxItem Content="Male"/>
                                                    <ComboBoxItem Content="Female"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <Button Click="OnEquipmentPreviewClick" Padding="0" HorizontalAlignment="Left"
                                                    ToolTip.Tip="Click to choose equipment graphic">
                                                <Border Classes="GfxPreview" Height="64" Width="64">
                                                    <Image Source="{Binding EquipmentPreview}" Stretch="None"/>
                                                </Border>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Basic Info Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="BASIC INFO" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Name" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedItem.Name}" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Graphic ID" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.GraphicId}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Equip GFX" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Type" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.ItemTypes}" SelectedItem="{Binding SelectedItem.Type}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Subtype" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.ItemSubtypes}" SelectedItem="{Binding SelectedItem.Subtype}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Special" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.ItemSpecials}" SelectedItem="{Binding SelectedItem.Special}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Weight" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Weight}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Size" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.ItemSizes}" SelectedItem="{Binding SelectedItem.Size}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Heal Stats Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowHealStats}">
                                        <StackPanel>
                                            <TextBlock Text="HEAL STATS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="HP Heal" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Hp}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="TP Heal" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Tp}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Weapon Stats Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowWeaponStats}">
                                        <StackPanel>
                                            <TextBlock Text="WEAPON STATS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Min Damage" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.MinDamage}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Max Damage" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.MaxDamage}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Accuracy" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Accuracy}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="HP Bonus" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Hp}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="TP Bonus" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Tp}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Defense Stats Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowDefenseStats}">
                                        <StackPanel>
                                            <TextBlock Text="DEFENSE STATS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Armor" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Armor}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Evade" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Evade}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Return Dmg" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.ReturnDamage}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="HP Bonus" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Hp}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="TP Bonus" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Tp}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Teleport Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowTeleportFields}">
                                        <StackPanel>
                                            <TextBlock Text="TELEPORT" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Map ID" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="X" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Spec2}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Y" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Spec3}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Spell Book Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowSpellField}">
                                        <StackPanel>
                                            <TextBlock Text="TEACHES SPELL" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Spell ID" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- EXP Reward Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowExpRewardField}">
                                        <StackPanel>
                                            <TextBlock Text="EXPERIENCE REWARD" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="EXP Amount" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Key Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowKeyField}">
                                        <StackPanel>
                                            <TextBlock Text="KEY PROPERTIES" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Key ID" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Effect Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowEffectField}">
                                        <StackPanel>
                                            <TextBlock Text="EFFECT" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Effect" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Hair Dye Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowHairDyeField}">
                                        <StackPanel>
                                            <TextBlock Text="HAIR DYE" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Hair Color" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedItem.Spec1}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Stat Bonuses Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowStatBonuses}">
                                        <StackPanel>
                                            <TextBlock Text="STAT BONUSES" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="STR" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Str}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="INT" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Intl}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="WIS" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Wis}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="AGI" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Agi}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="CON" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Con}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="CHA" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.Cha}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Requirements Card -->
                                    <Border Classes="SectionCard" IsVisible="{Binding ShowRequirements}">
                                        <StackPanel>
                                            <TextBlock Text="REQUIREMENTS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Level" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.LevelRequirement}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Class" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.ClassRequirement}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="STR Req" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.StrRequirement}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="INT Req" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.IntRequirement}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="WIS Req" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.WisRequirement}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="AGI Req" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.AgiRequirement}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="CON Req" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.ConRequirement}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="CHA Req" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedItem.ChaRequirement}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>
            
            <!-- ═══════════════════════════════════════════ -->
            <!-- NPCs Tab -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="NPCs">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Classes="Toolbar">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding NpcTypeFilters}" SelectedItem="{Binding SelectedNpcTypeFilter}" 
                                      Width="110" PlaceholderText="All Types" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="✕" Click="OnClearNpcTypeFilter" Padding="4,3" Margin="0,0,8,0"
                                    ToolTip.Tip="Show all types" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Text="{Binding NpcSearchText}" Width="140" Watermark="🔍 Search NPCs..." Margin="0,0,4,0"/>
                            <Panel Grid.Column="3"/>
                            <Button Grid.Column="4" Content="+ Add" Command="{Binding AddNpcCommand}" Classes="Primary" Margin="0,0,4,0"/>
                            <Button Grid.Column="5" Content="Delete" Command="{Binding DeleteNpcCommand}" Classes="Danger"
                                    IsEnabled="{Binding SelectedNpc, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </Grid>
                    </Border>
                    
                    <Grid ColumnDefinitions="220,*">
                        <ListBox Grid.Column="0" ItemsSource="{Binding FilteredNpcs}" SelectedItem="{Binding SelectedNpc}" Margin="6,6,3,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{ReflectionBinding Id, StringFormat='#{0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Width="32"/>
                                        <TextBlock Text="{ReflectionBinding Name}" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Border Grid.Column="1" Classes="EditorPanel" Margin="3,6,6,6">
                            <ScrollViewer>
                                <StackPanel IsVisible="{Binding SelectedNpc, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Border Classes="GoldAccent"/>
                                    <TextBlock Text="NPC Editor" Classes="PanelTitle"/>
                                    
                                    <!-- GFX Preview -->
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Graphic" FontSize="10" Classes="Label" Margin="0,0,0,3"/>
                                        <Button Click="OnNpcPreviewClick" Padding="0" HorizontalAlignment="Left"
                                                ToolTip.Tip="Click to choose a different graphic">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Export All Graphics..." Click="OnExportNpcGraphics"/>
                                                    <MenuItem Header="Import Graphics..." Click="OnImportNpcGraphics"/>
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Border Classes="GfxPreview" Height="64" Width="64">
                                                <Image Source="{Binding NpcPreview}" Stretch="None"/>
                                            </Border>
                                        </Button>
                                    </StackPanel>
                                    
                                    <!-- Basic Info Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="BASIC INFO" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Name" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedNpc.Name}" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Graphic ID" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.GraphicId}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Race" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.Race}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Type" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.NpcTypes}" SelectedItem="{Binding SelectedNpc.Type}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Behavior" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.BehaviorId}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Combat Stats Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="COMBAT STATS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="HP" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.Hp}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="TP" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.Tp}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Min Damage" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.MinDamage}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Max Damage" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.MaxDamage}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Accuracy" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.Accuracy}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Evade" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.Evade}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Armor" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.Armor}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Return Dmg" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.ReturnDamage}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="Experience" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedNpc.Experience}"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Flags Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="FLAGS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <CheckBox Content="Boss" IsChecked="{Binding SelectedNpc.Boss}"/>
                                                <CheckBox Content="Child" IsChecked="{Binding SelectedNpc.Child}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Weaknesses Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="WEAKNESSES" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Element" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.Elements}" SelectedItem="{Binding SelectedNpc.ElementWeakness}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Bonus Dmg" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedNpc.ElementWeaknessDamage}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>
            
            <!-- ═══════════════════════════════════════════ -->
            <!-- Spells Tab -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="Spells">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Classes="Toolbar">
                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding SpellTypeFilters}" SelectedItem="{Binding SelectedSpellTypeFilter}" 
                                      Width="110" PlaceholderText="All Types" Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="✕" Click="OnClearSpellTypeFilter" Padding="4,3" Margin="0,0,8,0"
                                    ToolTip.Tip="Show all types" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Text="{Binding SpellSearchText}" Width="140" Watermark="🔍 Search spells..." Margin="0,0,4,0"/>
                            <Panel Grid.Column="3"/>
                            <Button Grid.Column="4" Content="+ Add" Command="{Binding AddSpellCommand}" Classes="Primary" Margin="0,0,4,0"/>
                            <Button Grid.Column="5" Content="Delete" Command="{Binding DeleteSpellCommand}" Classes="Danger"
                                    IsEnabled="{Binding SelectedSpell, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </Grid>
                    </Border>
                    
                    <Grid ColumnDefinitions="220,*">
                        <ListBox Grid.Column="0" ItemsSource="{Binding FilteredSpells}" SelectedItem="{Binding SelectedSpell}" Margin="6,6,3,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{ReflectionBinding Id, StringFormat='#{0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Width="32"/>
                                        <TextBlock Text="{ReflectionBinding Name}" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Border Grid.Column="1" Classes="EditorPanel" Margin="3,6,6,6">
                            <ScrollViewer>
                                <StackPanel IsVisible="{Binding SelectedSpell, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Border Classes="GoldAccent"/>
                                    <TextBlock Text="Spell Editor" Classes="PanelTitle"/>
                                    
                                    <!-- GFX Previews -->
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="Spell GFX" FontSize="10" Classes="Label" Margin="0,0,0,3"/>
                                            <Button Click="OnSpellPreviewClick" Padding="0" HorizontalAlignment="Left"
                                                    ToolTip.Tip="Click to choose spell graphic (gfx024)">
                                                <Button.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Export All Graphics..." Click="OnExportSpellGraphics"/>
                                                        <MenuItem Header="Import Graphics..." Click="OnImportSpellGraphics"/>
                                                    </ContextMenu>
                                                </Button.ContextMenu>
                                                <Border Classes="GfxPreview" Height="64" Width="64">
                                                    <Image Source="{Binding SpellPreview}" Stretch="None"/>
                                                </Border>
                                            </Button>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Spell Icon" FontSize="10" Classes="Label" Margin="0,0,0,3"/>
                                            <Button Click="OnSpellIconPreviewClick" Padding="0" HorizontalAlignment="Left"
                                                    ToolTip.Tip="Click to choose spell icon (gfx025)">
                                                <Border Classes="GfxPreview" Height="64" Width="64">
                                                    <Image Source="{Binding SpellIconPreview}" Stretch="None"/>
                                                </Border>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Basic Info Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="BASIC INFO" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Name" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedSpell.Name}" Margin="0,0,0,6"/>
                                            <TextBlock Text="Chant" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedSpell.Chant}" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Icon ID" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.IconId}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Graphic ID" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.GraphicId}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Costs & Timing Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="COSTS &amp; TIMING" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="TP Cost" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.TpCost}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="SP Cost" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.SpCost}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="Cast Time" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.CastTime}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Effects Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="EFFECTS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Type" Classes="FieldLabel"/>
                                            <ComboBox ItemsSource="{Binding $parent[Window].DataContext.SkillTypes}" SelectedItem="{Binding SelectedSpell.Type}" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                                            <Grid ColumnDefinitions="*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Min Damage" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.MinDamage}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Max Damage" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.MaxDamage}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="HP Heal" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.HpHeal}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Accuracy" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedSpell.Accuracy}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Targeting Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="TARGETING" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Target" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.SkillTargetTypes}" SelectedItem="{Binding SelectedSpell.TargetType}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Restrict" Classes="FieldLabel"/>
                                                    <ComboBox ItemsSource="{Binding $parent[Window].DataContext.SkillTargetRestricts}" SelectedItem="{Binding SelectedSpell.TargetRestrict}" HorizontalAlignment="Stretch"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>
            
            <!-- ═══════════════════════════════════════════ -->
            <!-- Classes Tab -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="Classes">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Classes="Toolbar">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                            <TextBox Grid.Column="0" Text="{Binding ClassSearchText}" Width="140" Watermark="🔍 Search classes..." Margin="0,0,4,0"/>
                            <Panel Grid.Column="1"/>
                            <Button Grid.Column="2" Content="+ Add" Command="{Binding AddClassCommand}" Classes="Primary" Margin="0,0,4,0"/>
                            <Button Grid.Column="3" Content="Delete" Command="{Binding DeleteClassCommand}" Classes="Danger"
                                    IsEnabled="{Binding SelectedClass, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        </Grid>
                    </Border>
                    
                    <Grid ColumnDefinitions="220,*">
                        <ListBox Grid.Column="0" ItemsSource="{Binding FilteredClasses}" SelectedItem="{Binding SelectedClass}" Margin="6,6,3,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{ReflectionBinding Id, StringFormat='#{0}'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Width="32"/>
                                        <TextBlock Text="{ReflectionBinding Name}" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <Border Grid.Column="1" Classes="EditorPanel" Margin="3,6,6,6">
                            <ScrollViewer>
                                <StackPanel IsVisible="{Binding SelectedClass, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <Border Classes="GoldAccent"/>
                                    <TextBlock Text="Class Editor" Classes="PanelTitle"/>
                                    
                                    <!-- Basic Info Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="BASIC INFO" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <TextBlock Text="Name" Classes="FieldLabel"/>
                                            <TextBox Text="{Binding SelectedClass.Name}" Margin="0,0,0,6"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Base Stats Card -->
                                    <Border Classes="SectionCard">
                                        <StackPanel>
                                            <TextBlock Text="BASE STATS" Classes="SectionHeader" Margin="0,0,0,6"/>
                                            <Grid ColumnDefinitions="*,8,*,8,*" Margin="0,0,0,4">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="STR" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedClass.Str}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="INT" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedClass.Intl}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="WIS" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedClass.Wis}"/>
                                                </StackPanel>
                                            </Grid>
                                            <Grid ColumnDefinitions="*,8,*,8,*">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="AGI" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedClass.Agi}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="CON" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedClass.Con}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="CHA" Classes="FieldLabel"/>
                                                    <TextBox Text="{Binding SelectedClass.Cha}"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- GFX Editor Tab                              -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Header="GFX Editor">
                <views:GfxEditorTab DataContext="{Binding GfxEditor}"/>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
